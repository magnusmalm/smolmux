{
    "name": "esp32-arduino-lvgl",
    "device_type": "mcu",
    "description": "Arduino-ESP32 + LVGL demo firmware that prints 'Hello Arduino!' and 'Setup done' after ESP-ROM boot (e.g. Waveshare ESP32-S3-Touch-LCD stock LVGL_Arduino). Little steady-state UART traffic after boot. Prefer esp-idf-uart for generic ESP-IDF apps.",
    "prompt_pattern": "",
    "commands": [
        "/* no shell on stock LVGL demos - hard-reset and capture banner */"
    ],
    "boot_banner": "ESP-ROM:",
    "boot_stall_timeout_ms": 8000,
    "boot_stages": [
        {"name": "rom", "pattern": "ESP-ROM:"},
        {"name": "flash_boot", "pattern": "SPI_FAST_FLASH_BOOT"},
        {"name": "app_entry", "pattern": "entry 0x"},
        {"name": "arduino_hello", "pattern": "Hello Arduino!"},
        {"name": "lvgl_ready", "pattern": "Setup done"}
    ],
    "custom_anomaly_patterns": [
        {"name": "guru_meditation", "pattern": "Guru Meditation Error", "severity": "critical"},
        {"name": "brownout", "pattern": "Brownout detector was triggered", "severity": "critical"},
        {"name": "panic_abort", "pattern": "abort\\(\\) was called", "severity": "critical"},
        {"name": "stack_smashing", "pattern": "Stack smashing protect", "severity": "critical"},
        {"name": "download_boot", "pattern": "DOWNLOAD_BOOT", "severity": "info"}
    ]
}
